{{!
    @template mod_spinningwheel/result_modal

    Displays the spin result in a modal.

    Context variables required for this template:
    * selectedtext - The text of the selected entry
    * pictureurl - Profile picture URL (optional)
    * haspicture - Whether a picture URL is available
    * winnermessage - Custom winner message (optional)
    * haswinnermessage - Whether a winner message is set

    Example context (json):
    {
        "selectedtext": "Alice",
        "pictureurl": "",
        "haspicture": false,
        "winnermessage": "",
        "haswinnermessage": false
    }
}}
<div class="text-center p-3">
    {{#haswinnermessage}}
    <div class="mb-2 fs-6">
        {{winnermessage}}
    </div>
    {{/haswinnermessage}}
    {{#haspicture}}
    <div class="mb-2">
        <img src="{{pictureurl}}" class="rounded-circle" width="60" height="60" alt="{{selectedtext}}">
    </div>
    {{/haspicture}}
    <div class="fs-3 fw-bold mb-1" aria-live="assertive">
        {{selectedtext}}
    </div>
</div>
