{{!
    @template mod_spinningwheel/examples

    Didactic examples page for the Spinning Wheel activity.

    Context variables required for this template:
    * viewurl - URL back to the activity view page
    * scenarios - Array of scenario objects with: number, title, situation, implementation, benefit, settings

    Example context (json):
    {
        "viewurl": "/mod/spinningwheel/view.php?id=1",
        "scenarios": [
            {
                "number": 1,
                "title": "Fair participation",
                "situation": "Some students always raise their hand...",
                "implementation": "The wheel is populated with all participants...",
                "benefit": "Random selection is perceived as fair...",
                "settings": "Entry source: Course participants..."
            }
        ]
    }
}}
<div class="mod-spinningwheel-examples">
    <div class="d-flex align-items-center mb-3">
        <a href="{{viewurl}}" class="btn btn-sm btn-outline-secondary me-3">
            &larr; {{#str}}back{{/str}}
        </a>
        <h3 class="mb-0">{{#str}}examples, mod_spinningwheel{{/str}}</h3>
    </div>
    <p class="text-muted mb-4">{{#str}}examples_intro, mod_spinningwheel{{/str}}</p>

    {{#scenarios}}
    <details class="mb-2 border rounded p-2">
        <summary class="fw-semibold">{{number}}. {{title}}</summary>
        <div class="ps-3 pt-2">
            <h6 class="fw-bold">{{#str}}example_situation, mod_spinningwheel{{/str}}</h6>
            <p>{{situation}}</p>
            <h6 class="fw-bold">{{#str}}example_implementation, mod_spinningwheel{{/str}}</h6>
            <p>{{implementation}}</p>
            <h6 class="fw-bold">{{#str}}example_benefit, mod_spinningwheel{{/str}}</h6>
            <p>{{benefit}}</p>
            <h6 class="fw-bold">{{#str}}example_settings, mod_spinningwheel{{/str}}</h6>
            <p>{{settings}}</p>
        </div>
    </details>
    {{/scenarios}}
</div>
